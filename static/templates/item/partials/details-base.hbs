  {{formGroup systemFields.consumeAction value=system.consumeAction}}
  {{formGroup systemFields.addToQuickRoll value=system.addToQuickRoll}}

  {{formGroup systemFields.modifierTags value=system.modifierTags classes="ms-double-field" elementType="textarea"}}
  {{formGroup systemFields.notes value=system.notes classes="ms-double-field" elementType="textarea"}}
