<header class='ms-header'>
  <div class='ms-portrait-wrapper'>
    <div class='ms-portrait'>
      <img
        src='{{source.img}}'
        data-action='editImage'
        data-edit='img'
      />
    </div>
  </div>

  <div class='ms-name-container'>
    <h1 class='ms-name ms-name-display {{ifThen action.name "" "placeholder"}}'>{{ifThen action.name action.name fields.name.label}}</h1>
    {{formInput fields.name value=source.name placeholder=fields.name.label}}
  </div>
</header>
