<div class='ms-tracker-editor'>
  <header class='ms-header'>
    <input type='text' value='{{tracker.name}}' class='ms-name-input' data-field='tracker.name' />
    <button id='clone-button' type='button' class='ms-button ms-reset-button' data-action='cloneTracker'
      data-tooltip='{{localize "GURPS.resourceTracker.editor.clone"}}'>
      <i class='fas fa-copy'></i>
    </button>
    <button id='clear-button' type='button' class='ms-button ms-delete-button' data-action='clearTracker'
      data-tooltip='{{localize "GURPS.resourceTracker.editor.clear"}}'>
      <i class='fas fa-eraser'></i>
    </button>
  </header>

  <div class='ms-content'>
    <section class='text-attributes ms-section'>
      <div class='ms-field'>
        <label for='min'>{{localize 'GURPS.minimum'}}<input id='min' type='number' value='{{tracker.min}}'
            class='tracker-input' data-field="tracker.min" />
        </label>
      </div>
      <div class='ms-field'>
        <label for='max'>{{localize 'GURPS.maximum'}}<input id='max' type='number' value='{{tracker.max}}'
            class='tracker-input' data-field="tracker.max" />
        </label>
      </div>
      <div class='ms-field'>
        <label for='current'>{{localize 'GURPS.current'}}<input id='current' type='number' value='{{tracker.value}}'
            class='tracker-input' data-field="tracker.value" />
        </label>
      </div>
      <div class='ms-field'>
        <label for='pdf'>{{localize 'GURPS.reference'}}<input id='pdf' type='text' value='{{tracker.pdf}}'
            class='tracker-input' data-field="tracker.pdf" />
        </label>
      </div>
      <div class='ms-field'>
        <label for='alias'>{{localize 'GURPS.resourceTracker.editor.alias'}}<input id='alias' type='text'
            value='{{tracker.alias}}' class='tracker-input' data-field="tracker.alias" />
        </label>
      </div>
    </section>

    <section class='checkbox-attributes ms-section'>
      <div class='ms-field'>
        <label for='useBreakpoints'>{{localize 'GURPS.resourceTracker.editor.useBreakpoints'}}
          <input type='checkbox' id='useBreakpoints' name='useBreakpoints' {{checked tracker.useBreakpoints}}
            data-field='tracker.useBreakpoints' />
        </label>
      </div>
      <div class='ms-field'>
        <label for='enforce-minimum'>{{localize 'GURPS.resourceTracker.editor.enforceMin'}}
          <input type='checkbox' id='enforce-minimum' name='enforce-minimum' {{checked tracker.isMinEnforced}}
            data-field='tracker.isMinEnforced' />
        </label>
      </div>
      <div class='ms-field'>
        <label for='enforce-maximum'>{{localize 'GURPS.resourceTracker.editor.enforceMax'}}
          <input type='checkbox' id='enforce-maximum' name='enforce-maximum' {{checked tracker.isMaxEnforced}}
            data-field='tracker.isMaxEnforced' />
        </label>
      </div>
      <div class='ms-field'>
        <label for='isAccumulator'>{{localize 'GURPS.resourceTracker.editor.isAccumulator'}}
          <input type='checkbox' id='isAccumulator' name='isAccumulator' {{checked tracker.isAccumulator}}
            data-field='tracker.isAccumulator' />
        </label>
      </div>
      <div class='ms-field'>
        <label for='damage-type'>{{localize 'GURPS.resourceDamageType'}}
          <input type='checkbox' id='damage-type' name='damage-type' {{checked tracker.isDamageType}}
            data-field='tracker.isDamageType' />
        </label>
      </div>
    </section>
  </div>

  <div class='ms-content'>
    <section class='thresholds ms-section'>
      <h3 class='section-header'><i class="fa-solid fa-temperature-list"></i>
        {{localize 'GURPS.resourceTracker.editor.thresholds'}}</h3>
      <div class='threshold-list'>
        <div class='ms-table-header'>{{localize 'GURPS.resourceCurrentValue'}}</div>
        <div class='ms-table-header'>{{localize 'GURPS.condition'}}</div>
        <div class='ms-table-header'>{{localize 'GURPS.color'}}</div>
        <div class="ms-table-header"></div>

        {{#each tracker.thresholds}}
          <div class='current-value'>
            <select data='{{@index}}' name='comparison' style='font-size: 120%;'>
              <option value='>' {{select-if comparison '>'}}>&gt;</option>
              <option value='≥' {{select-if comparison '≥'}}>&ge;</option>
              <option value='<' {{select-if comparison '<'}}>&lt;</option>
              <option value='≤' {{select-if comparison '≤'}}>&le;</option>
            </select>
            <select name='operator' data='{{@index}}'>
              <option value='+' {{select-if operator '+'}}>{{localize 'GURPS.max'}} &plus;</option>
              <option value='−' {{select-if operator '−'}}>{{localize 'GURPS.max'}} &minus;</option>
              <option value='×' {{select-if operator '×'}}>{{localize 'GURPS.max'}} &times;</option>
              <option value='÷' {{select-if operator '÷'}}>{{localize 'GURPS.max'}} &divide;</option>
            </select>
            <input type='text' name='value' data='{{@index}}' value='{{value}}' />
          </div>
          <input type='text' name='condition' data='{{@index}}' value='{{condition}}' />
          <input type='color' name='color' data='{{@index}}' value='{{color}}' />
          <i class='fas fa-trash ms-action-btn ms-delete' data-action='deleteThreshold' data-key='{{@index}}'
            title='{{localize 'GURPS.delete'}}'></i>
        {{/each}}
      </div>
      <footer>
        <div class="ms-add-row">
          <span class="ms-add-btn" data-action="addThreshold"><i
              class="fas fa-plus"></i>{{localize 'GURPS.resourceTracker.editor.threshold'}}</span>
        </div>
      </footer>
    </section>
  </div>

  <footer class='ms-footer'>
    <button type='button' class='ms-button ms-save-button'><i class="fa-solid fa-floppy-disk"></i>{{localize 'GURPS.update'}}</button>
    <button type='button' class='ms-button ms-cancel-button'><i class="fa-solid fa-ban"></i>{{localize 'GURPS.cancel'}}</button>
  </footer>
</div>
