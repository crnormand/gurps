<div id='combat-trackers'>
  <div class='header'>
    <div class='headermenu' data-key='system.additionalresources.tracker'>
      <span>{{localize 'GURPS.resourceTracker.view.title'}}</span>
      <i class='fa-solid fa-square-caret-down'></i>
    </div>
  </div>
  <div id='tracker-scroller'>
    {{#each trackers}}
      {{>resource-tracker
          label=name
          resource=this
          name=(concat 'additionalresources.tracker.' (zeroFill @index 4))
          editable=true
        }}
    {{/each}}
  </div>
</div>
