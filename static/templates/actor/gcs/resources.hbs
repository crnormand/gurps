{{#*inline ".attributeEntry"}}
  <div class="form-group form-group-inverse">
    <div class="form-fields">
      {{formInput field value=value localize=true}}
    </div>
    <label>{{field.label}}</label>
  </div>
{{/inline}}

<section>
  <div class="gcs-attributes">
    <div class="gcs-primary-attributes gcs-section">
      <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.primaryAttributes"}}</div>
      <div class="gcs-field-rows gcs-field-rows-reverse gcs-section-content">
        {{> ".attributeEntry" field=systemFields.attributes.fields.ST.fields.import value=systemSource.attributes.ST.import}}
        {{> ".attributeEntry" field=systemFields.attributes.fields.DX.fields.import value=systemSource.attributes.DX.import}}
        {{> ".attributeEntry" field=systemFields.attributes.fields.IQ.fields.import value=systemSource.attributes.IQ.import}}
        {{> ".attributeEntry" field=systemFields.attributes.fields.HT.fields.import value=systemSource.attributes.HT.import}}
      </div>
    </div>
    <div class="gcs-basic-damage gcs-section">
      <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.basicDamage"}}</div>
      <div class="gcs-field-rows gcs-field-rows-reverse gcs-section-content">
        {{> ".attributeEntry" field=systemFields.thrust value=systemSource.thrust}}
        {{> ".attributeEntry" field=systemFields.swing value=systemSource.swing}}
      </div>
    </div>
    <div class="gcs-secondary-attributes gcs-section">
      <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.secondaryAttributes"}}</div>
      <div class="gcs-field-rows gcs-field-rows-reverse gcs-section-content">
        {{> ".attributeEntry" field=systemFields.attributes.fields.WILL.fields.import value=systemSource.attributes.WILL.import}}
        {{> ".attributeEntry" field=systemFields.frightcheck value=systemSource.frightcheck}}
        {{> ".attributeEntry" field=systemFields.attributes.fields.PER.fields.import value=systemSource.attributes.PER.import}}
        {{> ".attributeEntry" field=systemFields.vision value=systemSource.vision}}
        {{> ".attributeEntry" field=systemFields.hearing value=systemSource.hearing}}
        {{> ".attributeEntry" field=systemFields.tastesmell value=systemSource.tastesmell}}
        {{> ".attributeEntry" field=systemFields.touch value=systemSource.touch}}
        {{> ".attributeEntry" field=systemFields.basicspeed.fields.value value=systemSource.basicspeed.value}}
        {{> ".attributeEntry" field=systemFields.basicmove.fields.value value=systemSource.basicmove.value}}
      </div>
    </div>
    <div class="gcs-pool-attributes gcs-section">
      <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.poolAttributes"}}</div>
      <div class="gcs-field-rows gcs-field-rows-reverse gcs-section-content">
      </div>
    </div>
  </div>
  <div class="gcs-body gcs-section">
    <div class="gcs-section-header">{{ systemSource.additionalresources.bodyplan }}</div>
    <table class="gcs-table  gcs-section-content">
      <thead>
        <tr>
          <th>Roll</th>
          <th>Location</th>
          <th>Penalty</th>
          <th>DR</th>
        </tr>
      </thead>
      <tbody>
        {{#each systemSource.hitlocationsV2 as |location|}}
          <tr>
            <td>{{location.rollText}}</td>
            <td>{{location.where}}</td>
            <td>{{location.penalty}}</td>
            <td>{{location._dr}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  <div class="gcs-encumbrance gcs-section">
    <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.encumbrance"}}</div>
    <table class="gcs-table  gcs-section-content">
      <thead>
        <tr>
          <th></th>
          <th>Level</th>
          <th>Max Load</th>
          <th>Move</th>
          <th>Dodge</th>
        </tr>
      </thead>
      <tbody>
        {{#each system.encumbrance as |enc|}}
          <tr>
            <td>
              {{#if enc.current}}
              <i class="fa-solid fa-weight-hanging"></i>
              {{/if}}
            </td>
            <td>{{localize (concat "GURPS.encumbranceLevel-" enc.level)}}</td>
            <td>{{ localize "GURPS.Actor.gcsSheet.pound" value=enc.weight }}</td>
            <td>{{enc.move}}</td>
            <td>{{enc.dodge}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    </div>
  </div>
  <div class="gcs-moving gcs-section">
    <div class="gcs-section-header">{{localize "GURPS.sheet.gcsActorSheet.moving"}}</div>
    <table class="gcs-table  gcs-section-content">
      <tbody>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.basiclift }}
          </td>
          <td>
            {{localize "GURPS.basicLift"}}
          </td>
        </tr>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.onehandedlift }}
          </td>
          <td>
            {{localize "GURPS.oneHandLift"}}
          </td>
        </tr>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.twohandedlift }}
          </td>
          <td>
            {{localize "GURPS.twoHandLift"}}
          </td>
        </tr>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.shove }}
          </td>
          <td>
            {{localize "GURPS.shoveAndKnockOver"}}
          </td>
        </tr>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.runningshove }}
          </td>
          <td>
            {{localize "GURPS.runningShoveAndKnockOver"}}
          </td>
        </tr>
        <tr>
          <td>
            {{ localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.shiftslightly }}
          </td>
          <td>
            {{localize "GURPS.shiftSlightly"}}
          </td>
        </tr>
        <tr>
          <td>
            {{localize "GURPS.Actor.gcsSheet.pound" value=system.liftingmoving.carryonback}}
          </td>
          <td>
            {{localize "GURPS.carryOnBack"}}
          </td>
        </tr>
      </tbody>
    </table>
    </div>
  </div>
</section>
