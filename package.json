{
  "description": "GURPS Game Aid",
  "devDependencies": {
    "@types/jquery": "^3.5.32",
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^4.1.0",
    "chokidar": "^4.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "purgecss": "^8.0.0",
    "sass": "^1.97.1",
    "showdown": "^2.1.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.0"
  },
  "name": "gurps",
  "overrides": {
    "fvtt-types": {
      "tinymce": "8.3.1"
    },
    "minimatch": "^10.2.2"
  },
  "scripts": {
    "build": "npm run clean && npm run build:code && npm run build:styles && npm run build:static",
    "build:code": "tsc && tsc-alias -p tsconfig.json",
    "build:static": "node build/sync-static-files.js",
    "build:styles": "sass --no-source-map src/styles/gurps.scss:dist/styles/gurps.css",
    "clean": "node build/clean.js",
    "dev": "npm run clean && npm run watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "foundry:release": "node build/foundry-release.cjs",
    "foundry:release:dry-run": "node build/foundry-release.cjs --dry-run",
    "gen:actor-methods": "node dev/scripts/generate-actor-methods.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "tdd": "vitest --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "watch": "node build/watch.mjs",
    "watch:code": "tsc-watch -p tsconfig.json --onSuccess \"tsc-alias -p tsconfig.json\" --onFailure \"tsc-alias -p tsconfig.json\"",
    "watch:styles": "sass --watch --update src/styles/gurps.scss:dist/styles/gurps.css"
  },
  "type": "module",
  "version": "1.0.0"
}
